datasource db {
    provider = "postgresql"
    url      = "postgresql://postgres:postgres@localhost:5432/cneeded"
}

generator client {
    provider  = "prisma-client-py"
    interface = "sync"
}

enum JobPostStatus {
    ACTIVE
    CLOSED
    BLOCKED
}

enum HandleType {
    EMAIL
    DM
    RESUME
}

enum JobTypes {
    REMOTE
    INOFFICE
    CONTRACTUAL
    FREELANCE
    QUICKIE
}

model JobCategory {
    id        Int       @id @default(autoincrement())
    category  String?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    JobPost   JobPost[]
}

model User {
    id          Int           @id @default(autoincrement())
    userid      String        @unique
    name        String?
    username    String?
    resume      String?
    JobPost     JobPost[]
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    Application Application[]
}

model JobPost {
    id          Int            @id @default(autoincrement())
    title       String?
    description String?
    company     String?
    jobType     JobTypes?
    status      JobPostStatus?
    pay         String?
    location    String?
    poster      User?          @relation(fields: [posterId], references: [id])
    posterId    Int?
    catId       Int?
    category    JobCategory?   @relation(fields: [catId], references: [id])
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt
    Application Application[]
}

model Application {
    id        Int      @id @default(autoincrement())
    message   String?
    contact   String?
    user      User?    @relation(fields: [userId], references: [id])
    userId    Int?
    post      JobPost? @relation(fields: [postId], references: [id])
    postId    Int?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
